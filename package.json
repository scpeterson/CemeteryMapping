{
  "name": "cemetery-mapping",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "node server/index.mjs",
    "dev:web": "vite --mode dev",
    "dev:web:test": "vite --mode test",
    "dev:web:stage": "vite --mode stage",
    "dev:web:prod": "vite --mode prod",
    "dev": "concurrently -k -s first -n api,web \"npm run api\" \"npm run dev:web\"",
    "dev:test": "APP_ENV=test concurrently -k -s first -n api,web \"npm run api\" \"npm run dev:web:test\"",
    "dev:stage": "APP_ENV=stage concurrently -k -s first -n api,web \"npm run api\" \"npm run dev:web:stage\"",
    "dev:prod": "APP_ENV=prod concurrently -k -s first -n api,web \"npm run api\" \"npm run dev:web:prod\"",
    "build": "tsc -b && vite build --mode prod",
    "build:dev": "tsc -b && vite build --mode dev",
    "build:test": "tsc -b && vite build --mode test",
    "build:stage": "tsc -b && vite build --mode stage",
    "build:prod": "tsc -b && vite build --mode prod",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:server": "node --test server/*.test.mjs",
    "test:e2e": "playwright test",
    "geodatabase:inspect": "node scripts/geodatabase-inspect.mjs",
    "geodatabase:export": "node scripts/geodatabase-export-layer.mjs",
    "db:up": "node scripts/db-compose.mjs up",
    "db:up:dev": "APP_ENV=dev node scripts/db-compose.mjs up",
    "db:up:test": "APP_ENV=test node scripts/db-compose.mjs up",
    "db:up:stage": "APP_ENV=stage node scripts/db-compose.mjs up",
    "db:up:prod": "APP_ENV=prod node scripts/db-compose.mjs up",
    "db:down": "node scripts/db-compose.mjs down",
    "db:down:dev": "APP_ENV=dev node scripts/db-compose.mjs down",
    "db:down:test": "APP_ENV=test node scripts/db-compose.mjs down",
    "db:down:stage": "APP_ENV=stage node scripts/db-compose.mjs down",
    "db:down:prod": "APP_ENV=prod node scripts/db-compose.mjs down",
    "db:logs": "node scripts/db-compose.mjs logs",
    "db:validate": "node scripts/db-liquibase.mjs validate",
    "db:status": "node scripts/db-liquibase.mjs status --verbose",
    "db:migrate": "node scripts/db-liquibase.mjs update",
    "db:rollback": "node scripts/db-rollback-count.mjs",
    "db:rollback:one": "node scripts/db-rollback-count.mjs 1",
    "db:rollback:tag": "node scripts/db-rollback-tag.mjs",
    "db:rollback:test": "node scripts/db-rollback-test.mjs",
    "db:import:geodatabase": "node scripts/db-import-geodatabase.mjs",
    "db:import:headstones": "node scripts/db-import-headstones-xlsx.mjs",
    "db:promote:spatial": "node scripts/db-promote-spatial-staging.mjs",
    "db:seed:demo": "node scripts/db-seed-demo.mjs",
    "db:validate:spatial": "node scripts/db-validate-spatial.mjs",
    "db:tag": "node scripts/db-tag.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-oauth2-jwt-bearer": "^1.9.0",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^5.6.2",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3"
  }
}
