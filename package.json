{
  "name": "cemetery-mapping",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:validate": "docker compose run --rm liquibase --defaults-file=/liquibase/changelog/liquibase.properties validate",
    "db:status": "docker compose run --rm liquibase --defaults-file=/liquibase/changelog/liquibase.properties status --verbose",
    "db:migrate": "docker compose run --rm liquibase --defaults-file=/liquibase/changelog/liquibase.properties update",
    "db:rollback": "node scripts/db-rollback-count.mjs",
    "db:rollback:one": "node scripts/db-rollback-count.mjs 1",
    "db:rollback:tag": "node scripts/db-rollback-tag.mjs",
    "db:rollback:test": "node scripts/db-rollback-test.mjs",
    "db:tag": "node scripts/db-tag.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^5.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3"
  }
}
