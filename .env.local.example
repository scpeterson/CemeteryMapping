# Copy to .env.local or export values in your shell for local overrides.
VITE_APP_ENV=DEV
VITE_API_BASE_URL=http://localhost:5173/api

# Auth0 test tenant values. Leave blank to run without frontend login.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://cemetery-mapping.test/api
VITE_AUTH0_SCOPE=read:cemetery write:cemetery
